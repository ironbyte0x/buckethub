{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "trailingComma": "none",
  "printWidth": 100,
  "experimentalSortPackageJson": true,
  "ignorePatterns": [
    "/dist",
    "/coverage",
    "/charts",
    "/.nx/cache",
    "/.nx/workspace-data",
    "/node_modules",
    "/**/node_modules",
    "/**/styled-system"
  ]
}
