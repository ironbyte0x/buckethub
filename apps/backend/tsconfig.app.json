{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "preserve",
    "types": ["bun"],
    "rootDir": "src",
    "moduleResolution": "bundler",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "jsx": "react-jsx"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ],
  "references": [
    {
      "path": "../../libs/test/tsconfig.lib.json"
    },
    {
      "path": "../../libs/core/tsconfig.lib.json"
    },
    {
      "path": "../../libs/rpc-contract/tsconfig.lib.json"
    }
  ]
}
