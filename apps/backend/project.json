    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/apps/backend/dist/package.json",
        "{workspaceRoot}/apps/backend/dist/bun.lock"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/apps/backend/dist/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "email-dev": {
      "continuous": true,
      "command": "email dev --dir src/shared/email/templates --port 3100",
      "options": {
        "cwd": "apps/backend"
      }
    },
    "serve": {
      "continuous": true,
      "command": "bun",
      "defaultConfiguration": "development",
      "dependsOn": ["watch-deps", "build-deps"],
      "options": {
        "cwd": "apps/backend",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "args": ["--hot", "/src/main.ts"]
        },
        "production": {
          "args": ["--hot", "/src/main.ts"],
          "buildTarget": "backend:build:production"
        }
      }
    }
  }
}
